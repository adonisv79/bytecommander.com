---
// Hero.astro
---

<section class="hero" id="home">
  <div class="container hero-content animate-slide-up">
    <div class="hero-text delay-100">
      <h2 class="greeting">Hello, I'm</h2>
      <h1 class="name">Adonis <span class="highlight">Villamor</span></h1>
      <h3 class="title">A traditional coder meets AI Product Engineer</h3>
      <p class="description">
        I design and optimize high-concurrency systems, transforming complex business requirements into elegant, scalable software. Driven by a passion for next-generation products, I leverage advanced AI orchestration—such as Claude Code, Codex, and Antigravity—to accelerate product cycles from concept to baseline at extreme speed.
      </p>
      
      <div class="cta-group">
        <a href="#projects" class="btn btn-primary">View My Work</a>
        <a href="https://www.linkedin.com/in/adonisv79/" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Let's Connect</a>
      </div>
    </div>
    
    <!-- Using a visual element instead of a generic portrait for the "Asian tech professional" vibe -->
    <div class="hero-visual delay-300">
      <div class="glow-orb"></div>
      <div class="glass-panel floating-card card-1">
        <span class="icon">⚡</span>
        <span>Parallel Programming</span>
      </div>
      <div class="glass-panel floating-card card-2">
        <span class="icon">🤖</span>
        <span>AI Orchestration</span>
      </div>
      <div class="glass-panel floating-card card-3">
        <span class="icon">🚀</span>
        <span>High-Concurrency</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: var(--spacing-xl) 0;
    position: relative;
    overflow: hidden;
  }

  /* subtle background texture */
  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 100vh;
    height: 100vh;
    background: radial-gradient(circle, rgba(0, 229, 255, 0.05) 0%, transparent 70%);
    border-radius: 50%;
    z-index: -1;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  @media (min-width: 992px) {
    .hero-content {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .greeting {
    font-family: var(--font-body);
    font-weight: 500;
    color: var(--primary-accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-size: 1rem;
    margin-bottom: var(--spacing-sm);
  }

  .name {
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1.1;
    margin-bottom: var(--spacing-sm);
    color: var(--text-main);
  }

  .highlight {
    background: linear-gradient(90deg, var(--primary-accent), var(--secondary-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  .title {
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: var(--text-muted);
    font-weight: 400;
    margin-bottom: var(--spacing-md);
  }

  .description {
    font-size: 1.125rem;
    color: var(--text-muted);
    max-width: 600px;
    margin-bottom: var(--spacing-lg);
  }

  .cta-group {
    display: flex;
    gap: var(--spacing-md);
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    text-align: center;
    transition: all var(--transition-normal);
  }

  .btn-primary {
    background-color: var(--primary-accent);
    color: var(--bg-color);
    box-shadow: 0 4px 15px rgba(0, 229, 255, 0.3);
  }

  .btn-primary:hover {
    background-color: #00cce6;
    color: var(--bg-color);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 229, 255, 0.4);
  }

  .btn-outline {
    background-color: transparent;
    color: var(--primary-accent);
    border: 1px solid var(--primary-accent);
  }

  .btn-outline:hover {
    background-color: rgba(0, 229, 255, 0.1);
    transform: translateY(-2px);
  }

  /* Visual Elements */
  .hero-visual {
    position: relative;
    height: 400px;
    display: none;
  }

  @media (min-width: 992px) {
    .hero-visual {
      display: block;
    }
  }

  .glow-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
    filter: blur(20px);
    border-radius: 50%;
    animation: pulse 6s ease-in-out infinite alternate;
  }

  .floating-card {
    position: absolute;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-heading);
    font-weight: 600;
    white-space: nowrap;
  }

  .icon {
    font-size: 1.5rem;
  }

  .card-1 {
    top: 20%;
    right: 10%;
    animation: float 4s ease-in-out infinite;
  }

  .card-2 {
    top: 50%;
    left: 5%;
    animation: float 5s ease-in-out infinite 1s;
  }

  .card-3 {
    bottom: 10%;
    right: 20%;
    animation: float 4.5s ease-in-out infinite 2s;
  }

  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }

  @keyframes pulse {
    0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    100% { transform: translate(-50%, -50%) scale(1.2); opacity: 1; }
  }
</style>
