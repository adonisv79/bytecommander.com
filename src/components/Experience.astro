---

<section class="experience" id="experience">
  <div class="container">
    <h2 class="section-title">Professional Experience</h2>
    
    <div class="timeline animate-slide-up delay-200">
      {experiences.map((exp, index) => (
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="glass-panel timeline-content">
            <div class="company-header">
              {exp.logo && <img src={`/images/companies/${exp.logo}`} alt={`${exp.company} logo`} class={`company-logo ${exp.colorTint ? 'logo-' + exp.colorTint : ''}`} />}
              <div class="company-title-wrapper">
                <h3 class="role">{exp.role}</h3>
                <h4 class="company">{exp.company} <span class="location">({exp.location})</span></h4>
              </div>
            </div>
            <p class="period">{exp.period}</p>
            <p class="description">{exp.description}</p>
            
            {exp.details && exp.details.length > 0 && (
              <div class="chat-dialog">
                <div class="chat-bubble">
                  <ul>
                    {exp.details.map(detail => (
                      <li>{detail}</li>
                    ))}
                  </ul>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .experience {
    padding: var(--spacing-xl) 0;
  }

  .timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    padding: var(--spacing-md) 0;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    left: 20px;
    width: 2px;
    background: rgba(255, 255, 255, 0.1);
  }

  @media (min-width: 768px) {
    .timeline::before {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  .timeline-item {
    position: relative;
    margin-bottom: var(--spacing-sm);
    z-index: 1; /* Base z-index */
  }

  .timeline-item:hover {
    z-index: 50; /* Bring the entire item to the front on hover so the dialog doesn't get buried by later elements */
  }

  /* Compact spacing for desktop staggered timeline */
  @media (min-width: 768px) {
    .timeline-item {
      margin-bottom: -40px; /* Pulls cards closer together vertically */
    }
    .timeline-item:last-child {
      margin-bottom: 0;
    }
  }

  .timeline-marker {
    position: absolute;
    left: 14px;
    top: 24px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--primary-accent);
    border: 3px solid var(--bg-color);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
    z-index: 1;
  }

  .timeline-content {
    margin-left: 50px;
    padding: var(--spacing-md);
    position: relative; /* For chat dialog absolute positioning */
  }

  .company-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xs);
  }

  .company-logo {
    height: 40px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    /* CSS Magic: Converts any white-background logo into a transparent, glowing neon cyan logo */
    filter: grayscale(1) invert(1) sepia(1) hue-rotate(140deg) saturate(400%) brightness(1.2) drop-shadow(0 0 8px rgba(0, 229, 255, 0.4));
    mix-blend-mode: screen;
  }

  .company-logo.logo-green {
    filter: grayscale(1) invert(1) sepia(1) hue-rotate(80deg) saturate(500%) brightness(1.2) drop-shadow(0 0 8px rgba(10, 255, 100, 0.4));
  }

  @media (min-width: 768px) {
    .company-header {
      flex-direction: row;
      align-items: center;
      gap: var(--spacing-md);
    }
    .timeline-item:nth-child(odd) .company-header {
      flex-direction: row-reverse; /* Align logo to the right for left-aligned cards */
    }
    
    .timeline-item:nth-child(odd) .timeline-content {
      margin-left: 0;
      margin-right: calc(50% + 40px);
      text-align: right;
    }
    .timeline-item:nth-child(even) .timeline-content {
      margin-left: calc(50% + 40px);
    }
    .timeline-item:nth-child(odd) .timeline-marker {
      left: 50%;
      transform: translateX(-50%);
    }
    .timeline-item:nth-child(even) .timeline-marker {
      left: 50%;
      transform: translateX(-50%);
    }
  }

  .role {
    font-size: 1.15rem;
    color: var(--text-main);
    margin-bottom: 2px;
  }
  
  .company-title-wrapper {
    display: flex;
    flex-direction: column;
  }

  .company {
    font-size: 0.95rem;
    color: var(--secondary-accent);
    margin-bottom: 0;
    font-weight: 500;
  }

  .location {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .period {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: var(--spacing-xs);
    margin-bottom: var(--spacing-sm);
    font-style: italic;
  }

  .description {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    line-height: 1.5;
  }
</style>

<style is:global>
  /* Global styles for Chat Dialog Hover Effect */
  /* This prevents Astro from silently dropping scoping on conditionally rendered map elements */
  
  /* Mobile First (Cards are on the right, marker on left) */
  .experience .chat-dialog {
    position: absolute;
    top: 100%; /* Pop below the card */
    left: 0;
    right: 0;
    width: auto; /* width auto with left/right 0 prevents horizontal overflow beyond parent bounds */
    padding-top: 15px; /* Invisible gap bridge */
    padding-left: 0;
    padding-right: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s;
    z-index: 100;
    pointer-events: none; /* Prevent flickering if mouse leaves card */
  }

  .experience .timeline-content:hover .chat-dialog {
    opacity: 1;
    visibility: visible;
    transform: translate(0, 0) !important;
  }

  .experience .chat-bubble {
    background: #0b0d10; /* Darker to contrast with card */
    border: 1px solid var(--primary-accent);
    border-radius: 12px;
    padding: var(--spacing-md);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.9), 0 0 20px rgba(0, 229, 255, 0.15);
    color: var(--text-main);
    text-align: left; /* Always left-align bullet points */
    font-size: 0.85rem;
    position: relative;
  }

  /* Triangle Pointer - Mobile (pointing up) */
  .experience .chat-bubble::before {
    content: '';
    position: absolute;
    bottom: 100%; /* Top of the bubble */
    left: 20px;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-bottom: 10px solid var(--primary-accent);
    border-top: none;
  }

  /* Last item on Mobile (Pop above the card) */
  .experience .timeline-item:last-child .chat-dialog {
    top: auto;
    bottom: 100%;
    padding-top: 0;
    padding-bottom: 15px;
    transform: translateY(-10px);
  }
  .experience .timeline-item:last-child .chat-bubble::before {
    bottom: auto;
    top: 100%;
    border-bottom: none;
    border-top: 10px solid var(--primary-accent);
  }

  /* Desktop Staggered Layout */
  @media (min-width: 768px) {
    /* Odd items are on the LEFT side of timeline, so dialog pops to the RIGHT */
    .experience .timeline-item:nth-child(odd) .chat-dialog {
      top: 10%;
      bottom: auto;
      left: 100%;
      right: auto;
      width: 320px;
      padding-top: 0;
      padding-bottom: 0;
      padding-left: 20px;
      padding-right: 0;
      transform: translateX(10px);
    }
    .experience .timeline-item:nth-child(odd) .chat-bubble::before {
      top: 20px;
      bottom: auto;
      left: -10px;
      right: auto;
      border-top: 10px solid transparent;
      border-bottom: 10px solid transparent;
      border-right: 10px solid var(--primary-accent);
      border-left: none;
    }

    /* Even items are on the RIGHT side of timeline, so dialog pops to the LEFT */
    .experience .timeline-item:nth-child(even) .chat-dialog {
      top: 10%;
      bottom: auto;
      left: auto;
      right: 100%;
      width: 320px;
      padding-top: 0;
      padding-bottom: 0;
      padding-left: 0;
      padding-right: 20px;
      transform: translateX(-10px);
    }
    .experience .timeline-item:nth-child(even) .chat-bubble::before {
      top: 20px;
      bottom: auto;
      left: auto;
      right: -10px;
      border-top: 10px solid transparent;
      border-bottom: 10px solid transparent;
      border-left: 10px solid var(--primary-accent);
      border-right: none;
    }

    /* Last item on Desktop: Grow upwards to avoid pushing page bottom */
    .experience .timeline-item:last-child .chat-dialog {
      top: auto;
      bottom: 0;
    }
    .experience .timeline-item:last-child .chat-bubble::before {
      top: auto;
      bottom: 20px;
    }
  }

  .experience .chat-bubble ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .experience .chat-bubble li {
    margin-bottom: 0.5rem;
    color: var(--text-muted);
    line-height: 1.4;
  }
  .experience .chat-bubble li:last-child {
    margin-bottom: 0;
  }
</style>
